# peSentinel environment variables (example)
# Copy to .env and fill in. Never commit .env.

# --- Reputation providers ---
# MalwareBazaar requires no API key. Leave unset.
MALWAREBAZAAR_API_URL=https://mb-api.abuse.ch/api/v1/

# VirusTotal API key. Free tier: 4 req/min.
# Get one at https://www.virustotal.com/gui/my-apikey
# If set, peSentinel uses VT instead of MalwareBazaar.
VIRUSTOTAL_API_KEY=

# --- Network ---
# Set to 1 to skip all network signals (air-gapped mode).
PESENTINEL_OFFLINE=0
