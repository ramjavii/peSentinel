# peSentinel environment variables (example)
# Copy to .env and fill in. Never commit .env.

# --- Reputation providers (Stage 1+) ---
# MalwareBazaar requires no API key. Leave unset.
MALWAREBAZAAR_API_URL=https://mb-api.abuse.ch/api/v1/

# VirusTotal API key (OPTIONAL, out of v1 scope). Free tier: 4 req/min.
# Get one at https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# --- Crypto (Stage 5) ---
# Path to Ed25519 private key for signing reports. If unset, a keypair
# is generated in data/keys/ on first use (gitignored).
PESENTINEL_SIGNING_KEY_PATH=

# --- Auth (Stage 2) ---
# Path to the S/Key code book for admin two-factor auth.
# Generated by `pesentinel --init-codebook` (Stage 2).
PESENTINEL_CODEBOOK_PATH=data/codebook.json

# --- Network (Stage 1) ---
# Set to 1 to skip all network signals (air-gapped mode).
PESENTINEL_OFFLINE=0

# --- Audit (Stage 2) ---
# Path to the append-only audit log.
PESENTINEL_AUDIT_LOG=data/audit.jsonl
